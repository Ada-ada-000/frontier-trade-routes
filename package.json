{
  "name": "frontier-trade-routes",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm -r typecheck",
    "move:build": "cd contracts/trade_routes && sui move build",
    "simulate:trade-routes": "node scripts/simulate-trade-routes.mjs",
    "seed:testnet": "node scripts/seed-testnet-trade-routes.mjs",
    "seed:testnet:initial": "node scripts/seed-testnet-trade-routes.mjs --initial"
  }
}
